# Salin file ini jadi ".env" (satu folder dengan file ini, di root proyek --
# BUKAN di dalam folder api/). JANGAN commit file .env yang sudah diisi.
#
# - Tanpa Docker (XAMPP lokal): DB_HOST=localhost
# - Dengan Docker (docker-compose.yml, join network "mybridge" yang sudah
#   ada): DB_HOST diisi NAMA CONTAINER MySQL Anda (bukan "localhost").

DB_HOST=crypmerce_db
DB_PORT=3306
DB_NAME=bantul_creative
DB_USER=root
DB_PASS=

# Port di HOST (komputer Anda) untuk mengakses web app ini, boleh dibiarkan default
WEB_PORT=8080
