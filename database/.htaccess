# Folder ini berisi dump/migrasi SQL (kredensial hash, komentar password seed,
# data user asli) yang TIDAK boleh bisa diunduh langsung lewat browser.
# Sebelumnya folder ini tidak punya proteksi apa pun.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
