# Skrip di sini hanya untuk dijalankan lewat CLI (php.exe tests/xxx.php) dan
# masing-masing sudah menolak akses browser (PHP_SAPI !== 'cli' -> 403).
# .htaccess ini menutup celah tambahan: mencegah listing nama-nama file di
# folder ini saat diakses langsung lewat browser (Options Indexes aktif
# secara default di XAMPP).
Options -Indexes
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
